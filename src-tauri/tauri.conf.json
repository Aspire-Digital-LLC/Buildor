{
  "$schema": "https://raw.githubusercontent.com/nicerdicer/tauri/refs/heads/v2/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "Buildor",
  "version": "0.0.1",
  "identifier": "com.productaflows.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Buildor v0.0.1",
        "width": 1400,
        "height": 900,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  }
}
